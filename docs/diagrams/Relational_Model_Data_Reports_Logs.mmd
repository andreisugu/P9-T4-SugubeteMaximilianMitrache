    STUDENT ||--o{ GRADE : receives
    DISCIPLINE ||--o{ GRADE : evaluates
    ACADEMIC_YEAR ||--o{ GRADE : scopes
    USER_ACCOUNT ||--o{ GRADE : grades

    USER_ACCOUNT ||--o{ DATA_IMPORT_JOB : initiates
    DATA_IMPORT_JOB ||--o{ VALIDATION_ERROR : produces
    DATA_IMPORT_JOB ||--o{ IMPORT_JOB_RULE : applies
    DATA_TRANSFORMATION_RULE ||--o{ IMPORT_JOB_RULE : used_in

    %% =========================
    %% CARDINALITIES — DOCUMENT MODULE
    %% =========================

    USER_ACCOUNT ||--o{ DOCUMENT : authors

    %% =========================
    %% CARDINALITIES — REPORTS MODULE
    %% =========================

    REPORT_DEFINITION ||--o{ REPORT_REQUEST : instantiates
    USER_ACCOUNT ||--o{ REPORT_REQUEST : requests
    REPORT_REQUEST ||--o| E_GRADE_CENTRALIZER : generates
    SPECIALIZATION ||--o{ E_GRADE_CENTRALIZER : grouped_by
    ACADEMIC_YEAR ||--o{ E_GRADE_CENTRALIZER : scopes
    E_GRADE_CENTRALIZER ||--|{ REPORT_ROW : contains
    STUDENT ||--o{ REPORT_ROW : represented_by
    REPORT_REQUEST ||--o{ REPORT_EXPORT : exported_as
    USER_ACCOUNT ||--o{ REPORT_EXPORT : exports

    %% =========================
    %% CARDINALITIES — SECURITY MODULE
    %% =========================

    USER_ACCOUNT ||--o{ AUTH_SESSION : authenticates_via

    USER_ACCOUNT ||--o{ USER_ROLE : assigned
    ROLE ||--o{ USER_ROLE : mapped
    ROLE ||--o{ ROLE_PERMISSION : grants
    PERMISSION ||--o{ ROLE_PERMISSION : granted_to
    ROLE ||--o{ ROLE_OPERATION : allows
    OPERATION ||--o{ ROLE_OPERATION : allowed_by

    USER_GROUP ||--|{ USER_GROUP_MEMBER : has
    USER_ACCOUNT ||--o{ USER_GROUP_MEMBER : member_of
    USER_ACCOUNT ||--o{ OUTLOOK_NOTIFICATION : sends
    USER_GROUP ||--o{ OUTLOOK_NOTIFICATION : broadcasts

    USER_ACCOUNT ||--o{ AUDIT_LOG_ENTRY : performs
    OPERATION ||--o{ AUDIT_LOG_ENTRY : categorizes
    DATA_IMPORT_JOB ||--o{ AUDIT_LOG_ENTRY : logged_for
    REPORT_REQUEST ||--o{ AUDIT_LOG_ENTRY : logged_for
    REPORT_EXPORT ||--o{ AUDIT_LOG_ENTRY : logged_for
    GRADE ||--o{ AUDIT_LOG_ENTRY : logged_for

    USER_ACCOUNT ||--o{ ROLLBACK_OPERATION : triggers
    RECOVERY_POINT ||--o{ ROLLBACK_OPERATION : target_of
    BACKUP_JOB ||--o{ BACKUP_JOB_RECOVERY_POINT : creates_link
    RECOVERY_POINT ||--o{ BACKUP_JOB_RECOVERY_POINT : linked_to