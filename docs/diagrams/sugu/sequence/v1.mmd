stateDiagram-v2
    
    state "Public Zone" as PublicZone {
        Unauthenticated
    }
    Unauthenticated: Unauthenticated (Public Portal)
    
    state "External Identity Provider" as IdP {
        SSO
    }
    SSO: SSO Subsystem Redirect (ucv.ro)
    
    state "AFSMS Core System" as Core {
        state access_decision <<choice>>
        Validate
        AssignRole
    }
    Validate: Token Validation (SAML/OAuth)
    AssignRole: Role Assignment (DB Query)
    
    state "Private Zone" as PrivateZone {
        Auth
    }
    Auth: Authenticated (Private Dashboard)
    
    state "Boundary Control" as Boundary {
        Denied
    }
    Denied: Access Denied / 403

    [*] --> Unauthenticated
    Unauthenticated --> SSO : Initiate Login
    SSO --> Validate : Return Token
    Validate --> AssignRole : Token Validated
    Validate --> Denied : Token Invalid/Expired
    AssignRole --> access_decision : Evaluate Identity
    access_decision --> Auth : Role Authorized
    access_decision --> Denied : Role Unauthorized
    
    Auth --> [*]
    Denied --> Unauthenticated : Redirect to Login